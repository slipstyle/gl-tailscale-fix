local uci = require "uci"
local cjson = require "cjson"
local fs = require "oui.fs"

local M = {}

local TS_FIX_CONFIG = "ts-fix"
local FW_CONFIG = "firewall"
local TS_CONFIG = "tailscale"

local DEFAULT_LOGIN_SERVER = "https://controlplane.tailscale.com"
local GL_TAILSCALE_SCRIPT = "/usr/bin/gl_tailscale"

-- Version check cache TTL (72 hours)
local CACHE_TTL = 259200

-- Cached tailscale version. Invalidated per-worker when the tailscaled
-- binary mtime changes (i.e. the Version Manager ran an update/restore).
-- Multiple nginx workers each hold their own cache; mtime check ensures
-- every worker re-reads after an update, without a nginx restart.
local cached_ts_version = nil
local cached_ts_version_mtime = 0

-- Helper: strip version suffix (e.g. "1.94.2-tiny.by.admon.1187" → "1.94.2")
local function base_ver(v)
    if v then return v:match("^([%d%.]+)") end
    return v
end

-- Helper: run a command and return stdout
local function exec(cmd)
    local r = ngx.pipe.spawn({"sh", "-c", cmd})
    if r then
        local data = r:stdout_read_all()
        r:wait()
        return data
    end
    return nil
end

-- Helper: get mtime of a file as unix seconds. Returns 0 if unavailable.
-- Uses "date -r" (BusyBox) since GL routers don't ship stat in PATH.
local function file_mtime(path)
    local r = ngx.pipe.spawn({"date", "-r", path, "+%s"})
    if not r then return 0 end
    local data = r:stdout_read_all()
    r:wait()
    return tonumber((data or ""):match("^(%d+)")) or 0
end

-- Helper: get installed tailscale version. Caches per-worker and
-- invalidates on tailscaled binary mtime change (Version Manager updates).
local function get_ts_version()
    local mtime = file_mtime("/usr/sbin/tailscaled")
    if cached_ts_version and mtime > 0 and mtime == cached_ts_version_mtime then
        return cached_ts_version
    end
    local ver = exec("/usr/sbin/tailscale version 2>/dev/null")
    cached_ts_version = ver and base_ver(ver:match("^(%S+)")) or "unknown"
    cached_ts_version_mtime = mtime
    return cached_ts_version
end

-- Helper: check if a cache file is stale (older than CACHE_TTL seconds)
-- Uses "date -r" (BusyBox) since GL routers don't have stat in PATH.
-- Array-form spawn avoids shell interpolation of path.
local function is_cache_stale(path)
    if not fs.access(path) then return true end
    local r = ngx.pipe.spawn({"date", "-r", path, "+%s"})
    if not r then return true end
    local mtime_str = r:stdout_read_all()
    r:wait()
    if not mtime_str then return true end
    local mtime = tonumber(mtime_str:match("^(%d+)"))
    if not mtime then return true end
    return (ngx.time() - mtime) >= CACHE_TTL
end

-- Helper: run a command and return exit code
local function exec_rc(cmd)
    local r = ngx.pipe.spawn({"sh", "-c", cmd})
    if r then
        r:stdout_read_all()
        local ok, reason, code = r:wait()
        if ok then return 0 end
        return code or 1
    end
    return 1
end

-- Helper: get tailscale status JSON
-- Guards with pgrep first — if tailscaled isn't running, returns nil
-- immediately instead of spawning a ~60MB Go process that hangs for 3s
-- until timeout. Prevents OOM amplification loops on 512MB routers where
-- dead tailscaled + piling CLI processes exhaust all memory.
local function tailscale_status()
    if exec_rc("pgrep -x tailscaled >/dev/null 2>&1") ~= 0 then
        return nil
    end
    local data = exec("timeout 3 /usr/sbin/tailscale status --json 2>/dev/null")
    if data and #data > 0 then
        local ok, r = pcall(cjson.decode, data)
        if ok and type(r) == "table" then
            return r
        end
    end
    return nil
end

-- Helper: get guest subnet CIDR from br-guest interface
local function get_guest_subnet()
    local data = exec("ip -4 addr show br-guest 2>/dev/null")
    if data then
        local a, b, c, prefix = data:match("inet (%d+)%.(%d+)%.(%d+)%.%d+/(%d+)")
        if a then
            return a .. "." .. b .. "." .. c .. ".0/" .. prefix
        end
    end
    return nil
end

-- Helper: get currently advertised routes from tailscale prefs
local function get_current_routes()
    local data = exec("/usr/sbin/tailscale debug prefs 2>/dev/null")
    if data then
        local ok, prefs = pcall(cjson.decode, data)
        if ok and type(prefs.AdvertiseRoutes) == "table" then
            return prefs.AdvertiseRoutes
        end
    end
    return {}
end

-- Helper: update advertised routes, adding or removing guest subnet
local function update_guest_route(enable)
    local guest_subnet = get_guest_subnet()
    if not guest_subnet then return end

    local routes = get_current_routes()
    local new_routes = {}
    local found = false

    for _, route in ipairs(routes) do
        if route == guest_subnet then
            found = true
            if enable then
                new_routes[#new_routes + 1] = route
            end
        else
            new_routes[#new_routes + 1] = route
        end
    end

    if enable and not found then
        new_routes[#new_routes + 1] = guest_subnet
    end

    local routes_str = table.concat(new_routes, ",")
    exec("/usr/sbin/tailscale set --advertise-routes=" .. routes_str .. " 2>/dev/null")
end

-- Helper: set guest→tailscale firewall forwardings enabled/disabled
local function set_guest_ts_fw(enabled)
    local c = uci.cursor()
    local changed = false

    local forwardings = {
        {name = "ts_fix_guest2ts", src = "guest", dest = "tailscale0"},
        {name = "ts_fix_ts2guest", src = "tailscale0", dest = "guest"},
    }

    for _, fwd in ipairs(forwardings) do
        local exists = c:get(FW_CONFIG, fwd.name)
        if exists and not enabled then
            c:delete(FW_CONFIG, fwd.name)
            changed = true
        elseif not exists and enabled then
            c:set(FW_CONFIG, fwd.name, "forwarding")
            c:set(FW_CONFIG, fwd.name, "src", fwd.src)
            c:set(FW_CONFIG, fwd.name, "dest", fwd.dest)
            changed = true
        end
    end

    if changed then
        c:commit(FW_CONFIG)
        ngx.pipe.spawn({"/etc/init.d/firewall", "reload"})
    end

    return changed
end

-- Helper: ensure tailscale0 zone masquerade is enabled (defense-in-depth
-- for cross-subnet routing — Tailscale's built-in SNAT can fail to
-- reinitialize after daemon restart on fw3 kernels).
-- Returns true when the desired state is reached (either already set, or
-- we set it successfully). Logs and returns false on unrecoverable errors.
local function ensure_masquerade()
    local c = uci.cursor()
    if not c:get(FW_CONFIG, "tailscale0") then
        ngx.log(ngx.WARN, "ts-fix: tailscale0 firewall zone not found — masquerade not configured")
        return false
    end
    -- Both IPv4 (masq) and IPv6 (masq6) masquerade are set on the tailscale0
    -- zone. Verified empirically: without masq6, forwarded LAN IPv6 fails to
    -- traverse the exit-node tunnel. masq6 provides the IPv6 SNAT, mirroring
    -- masq's defense-in-depth role for IPv4.
    if c:get(FW_CONFIG, "tailscale0", "masq") == "1"
       and c:get(FW_CONFIG, "tailscale0", "masq6") == "1" then
        return true  -- both already set
    end
    local ok = c:set(FW_CONFIG, "tailscale0", "masq", "1")
    ok = c:set(FW_CONFIG, "tailscale0", "masq6", "1") and ok
    if not ok then
        ngx.log(ngx.ERR, "ts-fix: failed to set firewall.tailscale0 masquerade")
        return false
    end
    if not c:commit(FW_CONFIG) then
        ngx.log(ngx.ERR, "ts-fix: failed to commit firewall config for masquerade")
        return false
    end
    ngx.pipe.spawn({"/etc/init.d/firewall", "reload"})
    return true
end

-- Helper: find the firewall zone section whose .name='wan'. Stock GL
-- configs use anonymous sections (e.g. @zone[1]) so we can't c:get by
-- "wan" directly — iterate to locate it. Returns the section name
-- (e.g. "cfg033f8e" or "wan" for a named section) or nil.
-- First-match: if a misconfigured firewall has duplicate name='wan' zones,
-- act on the first (the iptables/nft chain GL's `wan` zone resolves to)
-- rather than the last — last-wins could land on a stale/duplicate section
-- with a different chain name. Red-team 2026-05-23.
local function find_wan_zone_section(c)
    local result = nil
    c:foreach(FW_CONFIG, "zone", function(s)
        if result == nil and s.name == "wan" then
            result = s[".name"]
        end
    end)
    return result
end

-- Helper: ensure wan-zone IPv6 masquerade when this router is acting as a
-- Tailscale exit node. Closes the pre-4.9 fw3 gap where Tailscale's own
-- ts-postrouting IPv6 chain is empty (verified empirically) AND pre-4.9
-- GL firmware doesn't reliably auto-set wan.masq6. Without it, forwarded
-- tailnet IPv6 (source fd7a:115c:a1e0::/48) exits with the ULA source
-- intact and is dropped upstream — silent IPv6 failure for tailnet clients
-- trying to use this router as an IPv6 exit node.
--
-- Sidecar flag ts-fix.settings.wan_masq6_set_by_plugin records whether WE
-- set masq6, so teardown only unsets it if our flag is on — never
-- trampling a GL- or user-managed value.
local function ensure_wan_v6_masq_for_exit_node(advertise_on)
    local c = uci.cursor()
    local wan_sec = find_wan_zone_section(c)
    if not wan_sec then
        ngx.log(ngx.WARN, "ts-fix: wan zone not found — exit-node v6 masquerade not configured")
        return
    end
    -- cur is nil (option not present), "" (rare), "0" (explicit off),
    -- or "1" (on). We distinguish "truly unset" from "user explicitly 0"
    -- so we don't trample a user's deliberate override (red-team 2026-05-23).
    local cur = c:get(FW_CONFIG, wan_sec, "masq6")
    local flag = c:get(TS_FIX_CONFIG, "settings", "wan_masq6_set_by_plugin") == "1"
    local changed = false
    if advertise_on then
        if not cur or cur == "" then
            -- masq6 truly unset → safe to set (user hasn't expressed intent)
            c:set(FW_CONFIG, wan_sec, "masq6", "1")
            c:set(TS_FIX_CONFIG, "settings", "wan_masq6_set_by_plugin", "1")
            changed = true
        elseif cur == "0" and flag then
            -- User explicitly set masq6=0 after we set it to 1. Respect the
            -- override: release ownership (clear our flag) but leave their 0.
            c:set(TS_FIX_CONFIG, "settings", "wan_masq6_set_by_plugin", "0")
            changed = true
        end
        -- If cur="0" with flag=0: user/GL chose 0, don't reclaim.
        -- If cur="1": no-op regardless of flag.
    else
        if flag then
            -- We previously set it. Delete the option (back to unset state)
            -- rather than setting to "0" — preserves the distinction between
            -- "user explicitly 0" and "option not present".
            c:delete(FW_CONFIG, wan_sec, "masq6")
            c:set(TS_FIX_CONFIG, "settings", "wan_masq6_set_by_plugin", "0")
            changed = true
        end
    end
    if changed then
        c:commit(FW_CONFIG)
        c:commit(TS_FIX_CONFIG)
        ngx.pipe.spawn({"/etc/init.d/firewall", "reload"})
    end
end

-- Helper: patch /usr/bin/gl_tailscale to set (or remove) --login-server.
-- Idempotent: strips any existing --login-server flag first, then inserts
-- the new one unless it matches the default Tailscale coordination server.
-- URL is validated to only contain characters safe for sed substitution
-- before being written into the script.
local function patch_gl_tailscale_login_server(url)
    -- Basic URL sanity: must start with http(s):// followed by safe chars only.
    -- This prevents command injection via the sed substitution.
    if url and url ~= "" and not url:match("^https?://[%w%.%-%_/:]+$") then
        ngx.log(ngx.WARN, "ts-fix: login_server URL failed validation, skipping patch: " .. tostring(url))
        return false
    end
    -- Strip any existing --login-server flag (idempotent)
    exec("sed -i 's/ --login-server [^ ]*//g' " .. GL_TAILSCALE_SCRIPT)
    -- Insert the new URL unless it is the default (no point cluttering the script)
    local effective = url and url ~= "" and url or DEFAULT_LOGIN_SERVER
    if effective ~= DEFAULT_LOGIN_SERVER then
        exec("sed -i 's|/usr/sbin/tailscale up |/usr/sbin/tailscale up --login-server " .. effective .. " |' " .. GL_TAILSCALE_SCRIPT)
    end
    return true
end

-- Helper: fix guest subnet policy route for exit node compatibility.
-- When the guest subnet is advertised, Tailscale creates a source-based rule
-- at priority 0: "from <guest_subnet> lookup main". This catches ALL traffic
-- originating from guest clients and sends it to the main table → WAN,
-- completely bypassing the exit node (priority 5270) AND the kill switch
-- (priority 5280). Replace with a destination-based rule: "to <guest_subnet>
-- table main" (matching Tailscale's own treatment of the LAN subnet). This
-- preserves inbound tailnet→guest reachability while letting guest clients
-- use the exit node. Confirmed by GL engineer prototype (gl_tailscale-guest).
local function fix_guest_policy_route(enabled)
    local guest_subnet = get_guest_subnet()
    if not guest_subnet then return end

    -- Always clean up both rule types to avoid duplicates
    exec("ip rule del from " .. guest_subnet .. " lookup main 2>/dev/null")
    exec("ip rule del to " .. guest_subnet .. " table main 2>/dev/null")

    if enabled then
        exec("ip rule add to " .. guest_subnet .. " table main priority 0")
    end
end

-- Helper: set kill switch routing rules (ip rule + ip route), both families.
-- Uses policy routing instead of firewall rules to block before conntrack.
-- Table 100 = unreachable default, priority 5280 = after Tailscale's 5270.
-- Applied to IPv4 and IPv6. "ip -6" errors are suppressed: if IPv6 is
-- compiled out the calls fail; if IPv6 is merely disabled the rules install
-- inert (no IPv6 traffic to act on). Neither case is harmful.
local function set_killswitch_route(enabled)
    for _, fam in ipairs({"-4", "-6"}) do
        if enabled then
            -- Ensure table 100 has unreachable default
            local rt = exec("ip " .. fam .. " route show table 100 2>/dev/null") or ""
            if not rt:match("unreachable default") then
                exec("ip " .. fam .. " route add unreachable default table 100 2>/dev/null")
            end
            -- Add ip rules for br-lan and br-guest (idempotent)
            local rules = exec("ip " .. fam .. " rule list priority 5280 2>/dev/null") or ""
            if not rules:match("iif br%-lan") then
                exec("ip " .. fam .. " rule add iif br-lan priority 5280 lookup 100 2>/dev/null")
            end
            if not rules:match("iif br%-guest") then
                exec("ip " .. fam .. " rule add iif br-guest priority 5280 lookup 100 2>/dev/null")
            end
        else
            -- Remove ip rules and route (suppress errors if not present)
            exec("ip " .. fam .. " rule del iif br-lan priority 5280 lookup 100 2>/dev/null")
            exec("ip " .. fam .. " rule del iif br-guest priority 5280 lookup 100 2>/dev/null")
            exec("ip " .. fam .. " route del unreachable default table 100 2>/dev/null")
        end
    end
end

-- Firmware detection — on GL 4.9+, some features overlap with GL's native
-- Tailscale enhancements. We keep the plugin fully active but hide UI for
-- features GL provides natively (Advertise Exit Node) and skip the
-- corresponding tailscale set calls. Cached at module load (firmware
-- version doesn't change at runtime).
local function detect_firmware()
    local f = io.open("/etc/glversion", "r")
    if not f then return "", false end  -- non-GL firmware
    local line = f:read("*l") or ""
    f:close()
    local ver = line:match("^(%S+)") or ""
    local major, minor = ver:match("^(%d+)%.(%d+)")
    if not major then return ver, false end
    major, minor = tonumber(major), tonumber(minor)
    local is_49_plus = major > 4 or (major == 4 and minor >= 9)
    return ver, is_49_plus
end

local firmware_version, fw_is_49_plus = detect_firmware()

--[[
    @method-type: call
    @method-name: get_config
    @method-desc: Get ts-fix configuration and live Tailscale state

    @out bool   advertise_exit_node    Whether exit node advertisement is enabled
    @out bool   kill_switch            Whether kill switch is enabled
    @out bool   route_guest            Whether guest network routing via Tailscale is enabled
    @out bool   exit_node_active       Whether this node is currently advertising as exit node (live)
    @out bool   ts_enabled             Whether Tailscale is enabled
    @out bool   ts_running             Whether Tailscale is in Running state
    @out string ts_version             Installed Tailscale version
    @out string exit_node_ip           Currently configured remote exit node IP (from GL config)
    @out bool   kill_switch_fw_active  Whether kill switch routing rules are currently active
    @out bool   route_guest_fw_active  Whether guest→tailscale forwardings are currently active
--]]
function M.get_config()
    -- Ensure masquerade on every config read (covers first page visit after
    -- install, even if no ts-fix features are active — needed for LAN clients
    -- to reach Tailscale peers through subnet routing). On 4.9+, GL owns the
    -- IP Masquerading toggle natively (under NAT on the Tailscale page) —
    -- defer entirely to avoid fighting the UI in the narrow edge case where
    -- the user has both LAN access and the masq toggle off.
    if not fw_is_49_plus then
        ensure_masquerade()
    end

    local c = uci.cursor()
    local res = {}

    -- Firmware info (drives per-feature UI gating on 4.9+)
    res.firmware_version = firmware_version
    res.firmware_49_plus = fw_is_49_plus

    -- Our UCI settings
    res.advertise_exit_node = c:get(TS_FIX_CONFIG, "settings", "advertise_exit_node") == "1"
    res.kill_switch = c:get(TS_FIX_CONFIG, "settings", "kill_switch") == "1"
    res.route_guest = c:get(TS_FIX_CONFIG, "settings", "route_guest") == "1"
    res.tailscale_ssh = c:get(TS_FIX_CONFIG, "settings", "tailscale_ssh") == "1"
    res.ks_upgrade_hint_pending = c:get(TS_FIX_CONFIG, "settings", "ks_upgrade_hint_pending") == "1"
    res.login_server = c:get(TS_FIX_CONFIG, "settings", "login_server") or DEFAULT_LOGIN_SERVER

    -- GL's Tailscale UCI settings
    res.ts_enabled = c:get(TS_CONFIG, "settings", "enabled") == "1"
    res.wan_enabled = c:get(TS_CONFIG, "settings", "wan_enabled") == "1"
    res.exit_node_ip = c:get(TS_CONFIG, "settings", "exit_node_ip") or ""

    -- Skip heavy tailscale CLI calls when TS is disabled (saves ~15MB RSS
    -- per call on 512MB routers where every MB counts against OOM)
    if res.ts_enabled then
        -- Live tailscale state
        local status = tailscale_status()
        if status then
            res.ts_running = status.BackendState == "Running"
            if status.Self then
                res.exit_node_active = status.Self.ExitNodeOption == true
                -- SSH live state: SSHHostKeys is present when SSH server is active
                res.ssh_active = type(status.Self.SSHHostKeys) == "table"
                    and #status.Self.SSHHostKeys > 0
            end
        else
            res.ts_running = false
            res.exit_node_active = false
            res.ssh_active = false
        end
    else
        res.ts_running = false
        res.exit_node_active = false
        res.ssh_active = false
    end

    -- Installed version (cached per-worker; auto-invalidates on tailscaled
    -- binary mtime change so Version Manager updates reflect without an
    -- nginx restart).
    res.ts_version = get_ts_version()

    -- Kill switch routing rule state — checked per family (IPv4 + IPv6).
    -- Reported active only when BOTH families' rules are present; a torn
    -- state (one family only, e.g. a partial reapply) reports false so the
    -- UI prompts a re-apply rather than silently claiming full protection.
    local ks_v4 = (exec("ip -4 rule list priority 5280 2>/dev/null") or ""):match("lookup 100") ~= nil
    local ks_v6 = (exec("ip -6 rule list priority 5280 2>/dev/null") or ""):match("lookup 100") ~= nil
    res.kill_switch_fw_active = ks_v4 and ks_v6

    -- Guest routing firewall forwarding state
    res.route_guest_fw_active = c:get(FW_CONFIG, "ts_fix_guest2ts") ~= nil

    -- Tailscale0 zone masquerade state — reported active only when BOTH
    -- families' masquerade are set (mirrors kill_switch_fw_active semantics;
    -- a torn state surfaces in the UI rather than silently claiming
    -- protection).
    res.masquerade_active = c:get(FW_CONFIG, "tailscale0", "masq") == "1"
        and c:get(FW_CONFIG, "tailscale0", "masq6") == "1"

    return res
end

--[[
    @method-type: call
    @method-name: set_config
    @method-desc: Apply ts-fix configuration changes

    @in  bool  ?advertise_exit_node   Enable/disable exit node advertisement
    @in  bool  ?kill_switch           Enable/disable kill switch
    @in  bool  ?route_guest           Enable/disable guest network routing via Tailscale
    @in  bool  ?tailscale_ssh         Enable/disable Tailscale SSH server
--]]
function M.set_config(params)
    local c = uci.cursor()

    -- Handle login_server before the ts_enabled guard: patching gl_tailscale
    -- doesn't require the daemon to be running.
    if params.login_server ~= nil then
        local url = params.login_server
        if url == "" then url = DEFAULT_LOGIN_SERVER end
        if not patch_gl_tailscale_login_server(url) then
            return { err_code = -4, err_msg = "Invalid login_server URL" }
        end
        c:set(TS_FIX_CONFIG, "settings", "login_server", url)
        if not c:commit(TS_FIX_CONFIG) then
            return { err_code = -3, err_msg = "Failed to commit login_server setting" }
        end
        -- If only login_server changed, return now (no daemon interaction needed).
        -- Caller must disable/re-enable Tailscale for the new URL to take effect.
        local other_keys = false
        for k, _ in pairs(params) do
            if k ~= "login_server" then other_keys = true; break end
        end
        if not other_keys then return {} end
    end

    -- Check tailscale is enabled
    local ts_enabled = c:get(TS_CONFIG, "settings", "enabled") == "1"
    if not ts_enabled then
        return { err_code = -1, err_msg = "Tailscale is not enabled" }
    end

    local exit_node_changed = false
    local route_changed = false
    local ssh_changed = false

    -- Handle advertise_exit_node
    if params.advertise_exit_node ~= nil then
        local val = params.advertise_exit_node and "1" or "0"
        c:set(TS_FIX_CONFIG, "settings", "advertise_exit_node", val)
        exit_node_changed = true
    end

    -- Handle kill_switch
    if params.kill_switch ~= nil then
        local val = params.kill_switch and "1" or "0"
        c:set(TS_FIX_CONFIG, "settings", "kill_switch", val)
        set_killswitch_route(params.kill_switch)
        -- User interacted with the KS toggle — clear the v1.0.18→v1.0.19
        -- migration hint whether they enabled or disabled it. The hint's
        -- job was to draw attention to the toggle, and they've seen it.
        c:set(TS_FIX_CONFIG, "settings", "ks_upgrade_hint_pending", "0")
    end

    -- Handle route_guest
    if params.route_guest ~= nil then
        local val = params.route_guest and "1" or "0"
        c:set(TS_FIX_CONFIG, "settings", "route_guest", val)
        set_guest_ts_fw(params.route_guest)
        route_changed = true
    end

    -- Handle tailscale_ssh
    if params.tailscale_ssh ~= nil then
        local val = params.tailscale_ssh and "1" or "0"
        c:set(TS_FIX_CONFIG, "settings", "tailscale_ssh", val)
        ssh_changed = true
    end

    if not c:commit(TS_FIX_CONFIG) then
        ngx.log(ngx.ERR, "ts-fix: failed to commit ts-fix config in set_config")
        return { err_code = -3, err_msg = "Failed to commit settings — check /etc/config/ts-fix permissions" }
    end
    fs.sync()

    -- Apply exit node setting (only when it was actually changed).
    -- On GL 4.9+, skip entirely — GL manages this natively via run_exit_node
    -- UCI, and running tailscale set would fight its state. The UCI value is
    -- still stored above for continuity if the user ever downgrades to 4.8.x.
    if exit_node_changed and not fw_is_49_plus then
        local advertise = c:get(TS_FIX_CONFIG, "settings", "advertise_exit_node") == "1"
        if advertise then
            exec("/usr/sbin/tailscale set --advertise-exit-node 2>/dev/null")
        else
            exec("/usr/sbin/tailscale set --advertise-exit-node=false 2>/dev/null")
        end
        -- Ensure wan-zone IPv6 masquerade so tailnet clients can use this
        -- router as an IPv6 exit node. Closes pre-4.9 fw3 gap where
        -- Tailscale's own ts-postrouting v6 chain is empty.
        ensure_wan_v6_masq_for_exit_node(advertise)
    end

    -- Apply SSH setting (only when it was actually changed)
    if ssh_changed then
        local ssh = c:get(TS_FIX_CONFIG, "settings", "tailscale_ssh") == "1"
        if ssh then
            exec("/usr/sbin/tailscale set --ssh 2>/dev/null")
        else
            exec("/usr/sbin/tailscale set --ssh=false 2>/dev/null")
        end
    end

    -- Apply route changes (only when route_guest was actually changed)
    if route_changed then
        local rg = c:get(TS_FIX_CONFIG, "settings", "route_guest") == "1"
        update_guest_route(rg)
        -- Fix policy route: swap Tailscale's "from <guest>" (blocks exit node
        -- + kill switch) with "to <guest>" (allows both). Must run after
        -- update_guest_route which triggers Tailscale to create its rules.
        fix_guest_policy_route(rg)
    end

    -- Ensure tailscale0 zone masquerade (defense-in-depth for subnet routing).
    -- On 4.9+, GL owns this — defer (see comment in get_config).
    if not fw_is_49_plus then
        ensure_masquerade()
    end

    return {}
end

--[[
    @method-type: call
    @method-name: get_update_info
    @method-desc: Get installed and latest Tailscale version info

    @out string installed_version   Currently installed version
    @out string latest_version      Latest stable version available
    @out bool   update_available    Whether an update is available
    @out string arch                Detected architecture
--]]
function M.get_update_info()
    local res = {}

    -- Installed version (cached per-worker with mtime invalidation)
    res.installed_version = get_ts_version()

    -- Architecture (hardcoded after first call — doesn't change at runtime)
    local arch = exec("uname -m 2>/dev/null")
    res.arch = arch and arch:match("^(%S+)") or "unknown"

    -- Check for cached latest version (updated by ts-fix-update --check)
    local cache_file = "/tmp/ts-fix-latest-version"
    if fs.access(cache_file) then
        local f = io.open(cache_file, "r")
        if f then
            res.latest_version = f:read("*l") or "unknown"
            f:close()
        end
        -- Background refresh if cache is stale (returns cached value, no UI flash)
        if is_cache_stale(cache_file) then
            ngx.pipe.spawn({"/usr/bin/ts-fix-update", "--check"})
        end
    else
        -- No cache — trigger async version check
        ngx.pipe.spawn({"/usr/bin/ts-fix-update", "--check"})
        res.latest_version = "checking..."
    end

    if res.installed_version ~= "unknown" and res.latest_version ~= "unknown"
       and res.latest_version ~= "checking..." then
        res.update_available = res.installed_version ~= res.latest_version
    else
        res.update_available = false
    end

    return res
end

--[[
    @method-type: call
    @method-name: do_update
    @method-desc: Update Tailscale to the latest version

    @out number ?err_code   Error code
    @out string ?err_msg    Error message
    @out string ?status     Status message
--]]
function M.do_update()
    -- Check if update is already running
    if fs.access("/tmp/ts-fix-update.lock") then
        return { err_code = -1, err_msg = "Update already in progress" }
    end

    -- Clear cached version (binary will change)
    cached_ts_version = nil

    -- Launch update in background
    ngx.pipe.spawn({"/usr/bin/ts-fix-update", "--install"})

    return { status = "update_started" }
end

--[[
    @method-type: call
    @method-name: get_update_status
    @method-desc: Get status of a running or completed update

    @out string status   "idle", "running", "success", "error"
    @out string message  Status or error message
--]]
function M.get_update_status()
    local status_file = "/tmp/ts-fix-update.status"
    if fs.access(status_file) then
        local f = io.open(status_file, "r")
        if f then
            local content = f:read("*a")
            f:close()
            local ok, data = pcall(cjson.decode, content)
            if ok then return data end
        end
    end
    return { status = "idle", message = "" }
end

--[[
    @method-type: call
    @method-name: do_restore
    @method-desc: Restore factory Tailscale binaries from /rom/

    @out number ?err_code   Error code
    @out string ?err_msg    Error message
--]]
function M.do_restore()
    -- Check /rom/ has factory binaries
    if not fs.access("/rom/usr/sbin/tailscale") then
        return { err_code = -1, err_msg = "Factory binaries not found in /rom/" }
    end

    -- Clear cached version (binary will change)
    cached_ts_version = nil

    ngx.pipe.spawn({"/usr/bin/ts-fix-update", "--restore"})
    return { status = "restore_started" }
end

--[[
    @method-type: call
    @method-name: get_plugin_info
    @method-desc: Get latest gl-tailscale-fix version from GitHub releases

    @out string latest_version   Latest plugin version ("checking...", "unavailable", or version string)
    @out string release_url      URL to the latest release page
--]]
function M.get_plugin_info()
    local res = {}
    local cache_file = "/tmp/ts-fix-plugin-latest-version"

    if fs.access(cache_file) then
        local f = io.open(cache_file, "r")
        if f then
            local version = f:read("*l") or ""
            local url = f:read("*l") or ""
            f:close()
            if version ~= "" then
                res.latest_version = version
                res.release_url = url
            else
                res.latest_version = "unavailable"
                res.release_url = ""
            end
        else
            res.latest_version = "unavailable"
            res.release_url = ""
        end
        -- Background refresh if cache is stale (returns cached value, no UI flash)
        if is_cache_stale(cache_file) then
            ngx.pipe.spawn({"/usr/bin/ts-fix-update", "--check-plugin"})
        end
    else
        -- No cache — trigger async version check
        ngx.pipe.spawn({"/usr/bin/ts-fix-update", "--check-plugin"})
        res.latest_version = "checking..."
        res.release_url = ""
    end

    return res
end

--[[
    @method-type: call
    @method-name: force_check_versions
    @method-desc: Force re-check of both Tailscale and plugin versions (clears cache)
--]]
function M.force_check_versions()
    ngx.pipe.spawn({"/usr/bin/ts-fix-update", "--check"})
    ngx.pipe.spawn({"/usr/bin/ts-fix-update", "--check-plugin"})
    return {}
end

--[[
    @method-type: call
    @method-name: dismiss_ks_hint
    @method-desc: Dismiss the post-upgrade "re-enable Kill Switch" hint.
    Called from the UI dismiss button; also cleared automatically when the
    user enables the kill switch via set_config.
--]]
function M.dismiss_ks_hint()
    local c = uci.cursor()
    if not c:set(TS_FIX_CONFIG, "settings", "ks_upgrade_hint_pending", "0") then
        return { err_code = -1, err_msg = "Failed to update ts-fix config" }
    end
    if not c:commit(TS_FIX_CONFIG) then
        return { err_code = -2, err_msg = "Failed to commit ts-fix config" }
    end
    return {}
end

return M
