#!/bin/sh
# gl-tailscale-fix: Re-apply settings after GL's "tailscale up --reset"
# Called by procd reload trigger (uci commit tailscale) and hotplug (ifup).
# Waits for GL's gl_tailscale restart to finish, then re-applies exit node,
# guest routes, firewall forwardings, and kill switch routing rules.
# Copyright (c) 2026 RemoteToHome Consulting (https://remotetohome.io)
# https://github.com/RemoteToHome-io/gl-tailscale-fix

# Firmware detection — on GL 4.9+, some features overlap with GL's native
# Tailscale enhancements. We keep the plugin fully active (kill switch, guest
# routing, SSH, Version Manager, masquerade) but skip operations that would
# fight GL's native layer (specifically: tailscale set --advertise-exit-node,
# which GL manages via run_exit_node UCI on 4.9+).
is_fw49_plus() {
    local fw_ver major minor
    fw_ver=$(awk '{print $1}' /etc/glversion 2>/dev/null)
    [ -z "$fw_ver" ] && return 1  # non-GL firmware — treat as < 4.9
    major=$(echo "$fw_ver" | cut -d. -f1)
    minor=$(echo "$fw_ver" | cut -d. -f2)
    if [ "$major" -gt 4 ] 2>/dev/null || \
       { [ "$major" -eq 4 ] && [ "$minor" -ge 9 ]; } 2>/dev/null; then
        return 0
    fi
    return 1
}

# Find the firewall zone section whose .name='wan'. Stock GL configs use
# anonymous sections (e.g. @zone[1]) so we iterate to locate it. Echoes
# the section name (e.g. "@zone[1]" or "cfg033f8e") on success, nothing
# on failure (caller treats empty as "no wan zone, skip").
find_wan_zone_section() {
    local s
    for s in $(uci -q show firewall 2>/dev/null | grep "=zone$" | cut -d= -f1 | sed 's/^firewall\.//'); do
        if [ "$(uci -q get firewall.$s.name 2>/dev/null)" = "wan" ]; then
            echo "$s"
            return 0
        fi
    done
    return 1
}

# Ensure wan-zone IPv6 masquerade when this router is acting as a Tailscale
# exit node. Closes the pre-4.9 fw3 gap: Tailscale's own v6 SNAT chain is
# empty on iptables/fw3 (verified empirically) AND pre-4.9 GL firmware
# doesn't reliably set wan.masq6. Without it, forwarded tailnet IPv6 exits
# with the Tailscale ULA source intact and is dropped upstream — silent
# IPv6 failure for tailnet clients trying to use this router as exit node.
# Idempotent. Sidecar flag ts-fix.settings.wan_masq6_set_by_plugin tracks
# whether WE set masq6, so teardown only unsets it if our flag is on —
# never trampling a GL- or user-managed value.
#
# Distinguishes "option not present" (cur empty) from "user explicit 0"
# (cur="0"). Only sets when truly unset; teardown uses `uci -q delete`
# instead of setting 0, so we don't fabricate a value that wasn't there.
# If user explicitly overrides our 1→0 after we set it, we release
# ownership (clear our flag) and respect their 0. Red-team 2026-05-23.
#
#   $1: "1" to ensure on, "0" to (conditionally) restore
ensure_wan_v6_masq_for_exit_node() {
    local on=$1 wan_sec cur flag changed=0
    wan_sec=$(find_wan_zone_section)
    [ -z "$wan_sec" ] && return 0
    cur=$(uci -q get "firewall.$wan_sec.masq6")
    flag=$(uci -q get ts-fix.settings.wan_masq6_set_by_plugin)
    if [ "$on" = "1" ]; then
        if [ -z "$cur" ]; then
            # masq6 truly unset → safe to set (user hasn't expressed intent)
            uci set "firewall.$wan_sec.masq6=1"
            uci set ts-fix.settings.wan_masq6_set_by_plugin=1
            changed=1
        elif [ "$cur" = "0" ] && [ "$flag" = "1" ]; then
            # User explicitly set masq6=0 after we set it to 1. Respect the
            # override: release ownership (clear our flag), leave their 0.
            uci set ts-fix.settings.wan_masq6_set_by_plugin=0
            changed=1
        fi
        # cur="0" with flag=0: user/GL chose 0, don't reclaim.
        # cur="1": no-op regardless of flag.
    else
        if [ "$flag" = "1" ]; then
            # We previously set it. Delete the option (back to unset state)
            # rather than setting "0" — preserves the distinction between
            # "user explicitly 0" and "option not present".
            uci -q delete "firewall.$wan_sec.masq6"
            uci set ts-fix.settings.wan_masq6_set_by_plugin=0
            changed=1
        fi
    fi
    if [ "$changed" = "1" ]; then
        uci commit firewall
        uci commit ts-fix
        /etc/init.d/firewall reload >/dev/null 2>&1
    fi
}

enabled=$(uci -q get tailscale.settings.enabled)

# If Tailscale is disabled, tear down all ts-fix state and exit.
# This covers the case where a user disables Tailscale while our switches
# are active — routing rules, firewall forwardings, and policy routes must
# be cleaned up, and UCI settings reset to 0 so everything starts clean
# when Tailscale is re-enabled.
if [ "$enabled" != "1" ]; then
    # Remove kill switch routing rules (both address families)
    for fam in -4 -6; do
        ip $fam rule del iif br-lan priority 5280 lookup 100 2>/dev/null
        ip $fam rule del iif br-guest priority 5280 lookup 100 2>/dev/null
        ip $fam route del unreachable default table 100 2>/dev/null
    done

    # Remove guest policy route fixup
    _gs=$(ip -4 addr show br-guest 2>/dev/null | awk '/inet /{print $2}' | sed 's|\.[0-9]*/|.0/|')
    [ -n "$_gs" ] && ip rule del to "$_gs" table main 2>/dev/null

    # Remove guest subnet from advertised routes (pgrep guard — avoids
    # spawning ~60MB Go process if daemon already stopped during disable)
    if [ -n "$_gs" ] && pgrep tailscaled >/dev/null 2>&1; then
        _cur=$(/usr/sbin/tailscale debug prefs 2>/dev/null | jsonfilter -e '@.AdvertiseRoutes[*]' 2>/dev/null | tr '\n' ',')
        case ",$_cur," in
            *",$_gs,"*)
                _new=$(echo "$_cur" | sed "s/${_gs},//;s/,${_gs}//;s/^${_gs}$//;s/,$//" )
                if [ -n "$_new" ]; then
                    /usr/sbin/tailscale set --advertise-routes="$_new" 2>/dev/null
                else
                    /usr/sbin/tailscale set --advertise-routes= 2>/dev/null
                fi
                ;;
        esac
    fi

    # Remove legacy UCI firewall kill switch rules (pre-v1.0.9)
    for section in ts_ks_lan2wan ts_ks_guest2wan; do
        uci -q delete firewall.$section 2>/dev/null
    done

    # Remove guest<->tailscale firewall forwardings and masquerade
    _fw=0
    [ -n "$(uci -q get firewall.ts_fix_guest2ts)" ] && {
        uci -q delete firewall.ts_fix_guest2ts
        uci -q delete firewall.ts_fix_ts2guest
        _fw=1
    }
    # On 4.9+, GL owns the IP Masquerading toggle — don't delete on teardown
    # (would trample GL's state). On pre-4.9, plugin set them, plugin clears.
    if ! is_fw49_plus; then
        if [ "$(uci -q get firewall.tailscale0.masq)" = "1" ] || \
           [ "$(uci -q get firewall.tailscale0.masq6)" = "1" ]; then
            uci -q delete firewall.tailscale0.masq
            uci -q delete firewall.tailscale0.masq6
            _fw=1
        fi
    fi
    [ "$_fw" = "1" ] && { uci commit firewall; /etc/init.d/firewall reload; }

    # If we set wan.masq6 for exit-node-server, restore it. Idempotent no-op
    # unless our sidecar flag is set, so we never trample a GL/user value.
    ensure_wan_v6_masq_for_exit_node 0

    # Disable Tailscale SSH (pgrep guard — avoids spawning Go process if daemon already stopped)
    pgrep tailscaled >/dev/null 2>&1 && /usr/sbin/tailscale set --ssh=false 2>/dev/null

    # Reset all ts-fix UCI settings to 0
    uci -q set ts-fix.settings.kill_switch=0
    uci -q set ts-fix.settings.route_guest=0
    uci -q set ts-fix.settings.advertise_exit_node=0
    uci -q set ts-fix.settings.tailscale_ssh=0
    uci commit ts-fix

    exit 0
fi

# Prevent concurrent runs (shared with hotplug and procd trigger)
LOCK="/tmp/ts-fix-reapply.lock"
exec 200>"$LOCK"
flock -n 200 || exit 0

# Ensure tailscale0 zone masquerade BEFORE waiting for tailscaled — this is a
# pure firewall setting that doesn't need the daemon. Required for LAN clients
# to reach Tailscale peers through subnet routing (SNAT return path).
# On 4.9+, GL owns the IP Masquerading toggle natively — defer to it (don't
# fight the UI in the narrow edge case where the user has both LAN access
# off and the masq toggle off).
if ! is_fw49_plus && [ -n "$(uci -q get firewall.tailscale0)" ]; then
    if [ "$(uci -q get firewall.tailscale0.masq)" != "1" ] || \
       [ "$(uci -q get firewall.tailscale0.masq6)" != "1" ]; then
        uci set firewall.tailscale0.masq=1
        uci set firewall.tailscale0.masq6=1
        uci commit firewall
        /etc/init.d/firewall reload >/dev/null 2>&1
    fi
fi

# Migration: remove legacy UCI firewall kill switch rules (pre-v1.0.9)
for section in ts_ks_lan2wan ts_ks_guest2wan; do
    [ -n "$(uci -q get firewall.$section)" ] && {
        uci -q delete firewall.$section
        uci commit firewall
    }
done

# GL's 19-tailscale-iface calls "gl_tailscale restart &" (async).
# That script does: tailscale restart -> network setup -> tailscale up --reset.
# We MUST wait for gl_tailscale to finish, otherwise --reset clears our settings.

# Wait for gl_tailscale to start (brief delay so the bg process appears)
sleep 3

# Wait for gl_tailscale to finish (up to 60s)
i=0
while [ $i -lt 60 ]; do
    pgrep -f "gl_tailscale restart" >/dev/null 2>&1 || break
    sleep 1
    i=$((i + 1))
done

# Now wait for Running state (up to 30s)
# pgrep guard avoids spawning ~60MB Go CLI while daemon is still starting
i=0
state=""
while [ $i -lt 30 ]; do
    if pgrep tailscaled >/dev/null 2>&1; then
        state=$(/usr/sbin/tailscale status --json 2>/dev/null | jsonfilter -e '@.BackendState' 2>/dev/null)
        [ "$state" = "Running" ] && break
    fi
    sleep 1
    i=$((i + 1))
done
[ "$state" = "Running" ] || exit 0

# Re-apply exit node advertisement (skip false — already cleared by --reset).
# On GL 4.9+, skip entirely — GL manages this natively via run_exit_node UCI.
adv=$(uci -q get ts-fix.settings.advertise_exit_node)
if [ "$adv" = "1" ] && ! is_fw49_plus; then
    /usr/sbin/tailscale set --advertise-exit-node 2>/dev/null
fi

# Ensure wan-zone IPv6 masquerade when this router is acting as a Tailscale
# exit node (closes pre-4.9 fw3 gap where Tailscale's own v6 SNAT chain is
# empty + pre-4.9 GL doesn't reliably set wan.masq6). Scoped to pre-4.9 —
# on 4.9+ GL owns the exit-node surface. The "off" branch is a safety net
# that restores wan.masq6 if a previous pre-4.9 install set it and the
# router is no longer acting as exit node (e.g. firmware upgraded to 4.9
# while advertise_exit_node was on; sidecar flag persists in UCI and we
# unwind on the next reapply).
if [ "$adv" = "1" ] && ! is_fw49_plus; then
    ensure_wan_v6_masq_for_exit_node 1
else
    ensure_wan_v6_masq_for_exit_node 0
fi

# Item 2: GL 4.9 Custom Exit Node reconciliation (defensive).
# PLAN observed 2026-04-24 that GL 4.9's Apply sometimes set
# `tailscale.settings.exit_node_ip` UCI without actually running
# `tailscale set --exit-node=<ip>` — daemon ended up with empty
# ExitNodeID, no table-52 default, user saw real IP. Pre-check
# 2026-05-23 couldn't reproduce via `gl_tailscale restart` on MT3000
# 4.9.0 (firmware unchanged per user — likely Tailscale binary update
# or environmental factor changed since). Defensive reconcile catches
# it if it reappears.
#
# Safety: value-snapshot signal. Track `last_seen_exit_node_ip` in
# our own UCI. Reconcile only when the user's UCI exit_node_ip is a
# NEW value (changed since our last reapply) AND daemon is empty AND
# the value is non-empty. Avoids the re-enable failure mode where
# unrelated GL Tailscale UCI commits bump /etc/config/tailscale mtime
# while exit_node_ip is stale from a past use. (Red-team 2026-05-23
# flagged the earlier mtime-only gate as insufficient — mtime doesn't
# isolate "exit_node_ip changed" from "any UCI key in this file changed".)
if is_fw49_plus; then
    gl_exit_ip=$(uci -q get tailscale.settings.exit_node_ip)
    ts_exit_id=$(/usr/sbin/tailscale debug prefs 2>/dev/null | jsonfilter -e '@.ExitNodeID' 2>/dev/null)
    last_seen=$(uci -q get ts-fix.settings.last_seen_exit_node_ip)
    if [ "$gl_exit_ip" != "$last_seen" ]; then
        # exit_node_ip value changed since our last reapply.
        if [ -n "$gl_exit_ip" ] && [ -z "$ts_exit_id" ]; then
            # New non-empty UCI but daemon hasn't caught up → reconcile.
            logger -t ts-fix "4.9 reconcile: UCI exit_node_ip changed to $gl_exit_ip but daemon ExitNodeID empty — running tailscale set --exit-node"
            /usr/sbin/tailscale set --exit-node="$gl_exit_ip" 2>/dev/null
        fi
        # Record current UCI value as our "last seen" regardless of
        # whether we reconciled. Next reapply with the SAME value is
        # treated as "no change, don't touch the daemon."
        uci set ts-fix.settings.last_seen_exit_node_ip="$gl_exit_ip"
        uci commit ts-fix
    fi
fi

# Re-apply Tailscale SSH (skip false — already cleared by --reset)
ts_ssh=$(uci -q get ts-fix.settings.tailscale_ssh)
[ "$ts_ssh" = "1" ] && /usr/sbin/tailscale set --ssh 2>/dev/null

# Re-apply guest subnet route advertisement
route_guest=$(uci -q get ts-fix.settings.route_guest)
guest_subnet=$(ip -4 addr show br-guest 2>/dev/null | awk '/inet /{print $2}' | sed 's|\.[0-9]*/|.0/|')
if [ "$route_guest" = "1" ]; then
    if [ -n "$guest_subnet" ]; then
        # Get current routes, add guest subnet if missing
        current=$(/usr/sbin/tailscale debug prefs 2>/dev/null | jsonfilter -e '@.AdvertiseRoutes[*]' 2>/dev/null | tr '\n' ',')
        case ",$current," in
            *",$guest_subnet,"*) ;; # already present
            *)
                new_routes="${current}${guest_subnet}"
                new_routes=$(echo "$new_routes" | sed 's/,$//')
                /usr/sbin/tailscale set --advertise-routes="$new_routes" 2>/dev/null
                ;;
        esac
    fi
else
    # Remove guest subnet from advertised routes if present
    if [ -n "$guest_subnet" ]; then
        current=$(/usr/sbin/tailscale debug prefs 2>/dev/null | jsonfilter -e '@.AdvertiseRoutes[*]' 2>/dev/null | tr '\n' ',')
        case ",$current," in
            *",$guest_subnet,"*)
                new_routes=$(echo "$current" | sed "s/${guest_subnet},//;s/,${guest_subnet}//;s/^${guest_subnet}$//;s/,$//" )
                if [ -n "$new_routes" ]; then
                    /usr/sbin/tailscale set --advertise-routes="$new_routes" 2>/dev/null
                else
                    /usr/sbin/tailscale set --advertise-routes= 2>/dev/null
                fi
                ;;
        esac
    fi
fi

# Fix guest subnet policy route for exit node + kill switch compatibility.
# Tailscale creates "from <guest_subnet> lookup main" at priority 0 when
# the guest subnet is advertised. This blocks guest clients from using the
# exit node AND bypasses the kill switch. Replace with "to <guest_subnet>"
# (destination-based, matching Tailscale's LAN treatment).
if [ "$route_guest" = "1" ] && [ -n "$guest_subnet" ]; then
    ip rule del from "$guest_subnet" lookup main 2>/dev/null
    ip rule del to "$guest_subnet" table main 2>/dev/null
    ip rule add to "$guest_subnet" table main priority 0
else
    # Clean up our destination-based rule if present
    _gs=$(ip -4 addr show br-guest 2>/dev/null | awk '/inet /{print $2}' | sed 's|\.[0-9]*/|.0/|')
    [ -n "$_gs" ] && {
        ip rule del to "$_gs" table main 2>/dev/null
    }
fi

# Sync firewall state (batched — single commit + reload at end)
_fw_dirty=0

# Guest routing firewall forwardings
if [ "$route_guest" = "1" ]; then
    if [ -z "$(uci -q get firewall.ts_fix_guest2ts)" ]; then
        uci set firewall.ts_fix_guest2ts=forwarding
        uci set firewall.ts_fix_guest2ts.src=guest
        uci set firewall.ts_fix_guest2ts.dest=tailscale0
        uci set firewall.ts_fix_ts2guest=forwarding
        uci set firewall.ts_fix_ts2guest.src=tailscale0
        uci set firewall.ts_fix_ts2guest.dest=guest
        _fw_dirty=1
    fi
else
    if [ -n "$(uci -q get firewall.ts_fix_guest2ts)" ]; then
        uci -q delete firewall.ts_fix_guest2ts
        uci -q delete firewall.ts_fix_ts2guest
        _fw_dirty=1
    fi
fi

# Single firewall commit + reload for all accumulated guest forwarding changes
[ "$_fw_dirty" = "1" ] && { uci commit firewall; /etc/init.d/firewall reload; }

# Sync kill switch routing rules (ip rule + ip route)
# Uses policy routing instead of firewall rules to block before conntrack.
# Table 100 = unreachable default, priority 5280 = after Tailscale's 5270.
kill_switch=$(uci -q get ts-fix.settings.kill_switch)

# Check actual tailscale exit node state — GL's UCI (tailscale.settings.exit_node_ip)
# is unreliable because GL does not clear it when Custom Exit Node is disabled via
# the admin panel (calls tailscale set --exit-node= but leaves UCI stale).
exit_node_id=$(/usr/sbin/tailscale debug prefs 2>/dev/null | jsonfilter -e '@.ExitNodeID' 2>/dev/null)

# Auto-disable kill switch if enabled but no exit node configured.
# This covers the case where a user disables Custom Exit Node while the
# kill switch is active — without this, the KS routing rules remain active
# but the KS toggle disappears from the UI (hidden when no exit node),
# blocking all LAN/guest traffic with no way to turn it off.
#
# IMPORTANT: ExitNodeID is transiently empty during gl_tailscale restart
# (tailscale up --reset clears it, then re-applies). If GL's UCI still has
# an exit_node_ip configured, we're in a restart transient — do NOT auto-
# disable. The watchdog handles the deliberate removal case (GL clears the
# exit node via tailscale set --exit-node= but leaves UCI stale).
gl_exit_ip=$(uci -q get tailscale.settings.exit_node_ip)
if [ "$kill_switch" = "1" ] && [ -z "$exit_node_id" ] && [ -z "$gl_exit_ip" ]; then
    uci -q set ts-fix.settings.kill_switch=0
    uci commit ts-fix
    kill_switch="0"
fi

if [ "$kill_switch" = "1" ] && [ -n "$exit_node_id" ]; then
    # Install kill switch routing rules for both address families.
    # "ip -6" errors are suppressed — harmless if IPv6 is compiled out
    # (calls fail) or merely disabled (rules install inert).
    for fam in -4 -6; do
        # Ensure table 100 has unreachable default
        ip $fam route show table 100 2>/dev/null | grep -q "unreachable default" || \
            ip $fam route add unreachable default table 100 2>/dev/null
        # Add ip rules for br-lan and br-guest (idempotent)
        ip $fam rule list priority 5280 2>/dev/null | grep -q "iif br-lan" || \
            ip $fam rule add iif br-lan priority 5280 lookup 100 2>/dev/null
        ip $fam rule list priority 5280 2>/dev/null | grep -q "iif br-guest" || \
            ip $fam rule add iif br-guest priority 5280 lookup 100 2>/dev/null
    done
else
    # Remove kill switch routing rules, both families (suppress errors)
    for fam in -4 -6; do
        ip $fam rule del iif br-lan priority 5280 lookup 100 2>/dev/null
        ip $fam rule del iif br-guest priority 5280 lookup 100 2>/dev/null
        ip $fam route del unreachable default table 100 2>/dev/null
    done
fi

# Explicit success — the trailing "ip ... del" returns rc 2 when the rules
# are already absent (normal KS-off path); don't propagate that as failure.
exit 0
